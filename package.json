{
  "name": "hub-vehicle-proof-capture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile-first Hub Vehicle Proof Capture app foundation for QR scan, Flash proof WebView automation, checklist photos, and exact 21.6 backup export.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "qa": "npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "typescript": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
